# ============================================
# Invoice Manager - Production Environment
# ============================================
# Copy this file to .env and customize:
#   cp .env.example .env

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeMe123!
POSTGRES_DB=invoice_db

# Database URL (internal docker network)
DATABASE_URL=postgresql+asyncpg://postgres:ChangeMe123!@db:5432/invoice_db

# Backend
DEBUG=false
SECRET_KEY=change-me-to-a-random-string

# ============================================
# LLM Configuration (at least one required)
# Uncomment and fill in your provider:
# ============================================

# Option 1: OpenAI / OpenAI-compatible (e.g. vLLM, OneAPI)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Option 2: Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Option 3: Google Gemini
# LLM_PROVIDER=google
# GOOGLE_API_KEY=xxxxxxxxxxxx

# Option 4: DeepSeek
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx

# Option 5: Zhipu (GLM)
# LLM_PROVIDER=zhipu
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxx

# Option 6: Qwen (Alibaba)
# LLM_PROVIDER=qwen
# QWEN_API_KEY=sk-xxxxxxxxxxxx
